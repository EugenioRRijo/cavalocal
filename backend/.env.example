# Servidor
PORT=3001
NODE_ENV=development

# Base de datos PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cavalocal?schema=public"

# Auth
JWT_SECRET="cambia-esto-en-produccion"
JWT_EXPIRES_IN="1d"

# CORS (orígenes separados por coma)
CORS_ORIGINS="*"

# Google OAuth (login con Google) — OAuth Client ID de Google Cloud Console
GOOGLE_CLIENT_ID="TU_GOOGLE_CLIENT_ID"

# Correo (Gmail SMTP) para la factura — crear una "contraseña de aplicación" de Gmail
MAIL_USER="tu-correo@gmail.com"
MAIL_APP_PASSWORD="TU_APP_PASSWORD_16_CHARS"
